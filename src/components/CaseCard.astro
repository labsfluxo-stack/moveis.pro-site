---
// src/components/CaseCard.astro
export interface Props {
  tag: string;
  title: string;
  description: string;
  metric: string;
  metricLabel: string;
  featured?: boolean;
}

const { tag, title, description, metric, metricLabel, featured = false } = Astro.props;
---

<article class={`case-card ${featured ? "is-featured row-span-2" : ""}`}>
  <div>
    <span class="tag">{tag}</span>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>

  <div class="metric-wrap">
    <strong>{metric}</strong>
    <span>{metricLabel}</span>
  </div>
</article>

<style>
  .case-card {
    position: relative;
    min-height: 220px;
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid var(--line);
    background:
      radial-gradient(circle at 100% 0%, rgba(184, 92, 58, 0.2) 0%, transparent 45%),
      rgba(247, 240, 232, 0.02);
    box-shadow: var(--card-shadow);
    overflow: hidden;
  }

  .case-card::after {
    content: "";
    position: absolute;
    bottom: -55%;
    right: -20%;
    width: 220px;
    height: 220px;
    background: radial-gradient(circle, rgba(205, 125, 94, 0.12), transparent 72%);
    pointer-events: none;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terra);
    margin-bottom: 14px;
  }

  .tag::before {
    content: "";
    width: 7px;
    height: 7px;
    background: var(--terra);
    border-radius: 2px;
    transform: rotate(45deg);
  }

  h3 {
    font-family: "Satoshi", "Inter", sans-serif;
    color: var(--cream);
    font-size: 25px;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 9px;
  }

  p {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.6;
    max-width: 94%;
  }

  .metric-wrap {
    margin-top: 24px;
  }

  .metric-wrap strong {
    display: block;
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 46px;
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--terra);
  }

  .metric-wrap span {
    color: var(--text-muted);
    font-size: 12px;
    margin-top: 4px;
    display: inline-block;
  }

  .is-featured h3 {
    font-size: 30px;
  }

  .is-featured .metric-wrap strong {
    font-size: 58px;
  }

  .case-card:hover {
    border-color: rgba(247, 240, 232, 0.24);
    transform: translateY(-2px);
  }
</style>
