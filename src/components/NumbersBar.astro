---
// src/components/NumbersBar.astro
export interface Props {
  items: Array<{ value: string; label: string }>;
}

const { items } = Astro.props;
---

<div class="numbers-wrap">
  <div class="numbers-grid" style={`grid-template-columns: repeat(${items.length}, 1fr);`}>
    {
      items.map((item, i) => (
        <div
          class="numbers-item"
          style={`${i < items.length - 1 ? "border-right: 1px solid var(--line);" : ""}`}
        >
          <div
            class="value"
            set:html={item.value.replace(
              /(\d+[\d.,]*[x%+\-]?)/g,
              `<em style="color: var(--terra); font-style: normal;">$1</em>`
            )}
          />
          <p class="label">{item.label}</p>
        </div>
      ))
    }
  </div>
</div>

<style>
  .numbers-wrap {
    position: relative;
    border-radius: 22px;
    border: 1px solid var(--line);
    background:
      radial-gradient(circle at 0% 100%, rgba(205, 125, 94, 0.15) 0%, transparent 38%),
      rgba(247, 240, 232, 0.02);
    overflow: hidden;
    box-shadow: var(--card-shadow);
    padding: 34px 20px;
  }

  .numbers-wrap::before {
    content: "";
    position: absolute;
    top: 0;
    left: 22%;
    right: 22%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(205, 125, 94, 0.85),
      transparent
    );
  }

  .numbers-grid {
    display: grid;
    gap: 0;
  }

  .numbers-item {
    padding: 0 24px;
  }

  .value {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: clamp(34px, 4.2vw, 52px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--cream);
    margin-bottom: 8px;
  }

  .label {
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.5;
    max-width: 220px;
  }

  @media (max-width: 980px) {
    .numbers-wrap {
      padding: 28px 14px;
    }
    .numbers-item {
      padding: 0 14px;
    }
  }
</style>
