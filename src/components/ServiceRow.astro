---
// src/components/ServiceRow.astro
export interface Props {
  number: string;
  name: string;
  description: string;
  badge: string;
  href: string;
}

const { number, name, description, badge, href } = Astro.props;
---

<a href={href} class="service-row-grid row">
  <span class="number">{number}</span>
  <span class="title">{name}</span>
  <span class="service-row-desc desc">{description}</span>
  <span class="service-row-badge badge">{badge}</span>
  <span class="arrow" aria-hidden="true">-></span>
</a>

<style>
  .row {
    display: grid;
    grid-template-columns: 66px 1fr 1.1fr 150px 30px;
    gap: 18px;
    align-items: center;
    border: 1px solid transparent;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    padding: 22px 14px;
    margin-left: -14px;
    margin-right: -14px;
    border-radius: 14px;
  }

  .number {
    color: var(--terra);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .title {
    color: var(--cream);
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 23px;
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 800;
  }

  .desc {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.52;
  }

  .badge {
    color: var(--text-dim);
    background: rgba(247, 240, 232, 0.05);
    border: 1px solid rgba(247, 240, 232, 0.16);
    border-radius: 999px;
    text-align: center;
    padding: 8px 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .arrow {
    color: var(--terra);
    opacity: 0;
    transform: translateX(-6px);
    font-size: 13px;
    font-weight: 800;
  }

  .row:hover {
    border-color: rgba(247, 240, 232, 0.16);
    background: rgba(247, 240, 232, 0.015);
  }

  .row:hover .title {
    color: #fffaf4;
  }

  .row:hover .arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 1024px) {
    .row {
      grid-template-columns: 54px 1fr 1fr 130px 24px;
    }
    .title { font-size: 20px; }
  }

  @media (max-width: 768px) {
    .row {
      grid-template-columns: 36px 1fr auto;
      grid-template-rows: auto auto;
      gap: 4px 12px;
      padding: 16px 10px;
      margin-left: -10px;
      margin-right: -10px;
    }

    /* número: linha 1 col 1 */
    .number {
      grid-column: 1;
      grid-row: 1;
      font-size: 10px;
      align-self: center;
    }

    /* título: linha 1 col 2 */
    .title {
      grid-column: 2;
      grid-row: 1;
      font-size: 17px;
    }

    /* seta: linha 1 col 3 */
    .arrow {
      grid-column: 3;
      grid-row: 1;
      opacity: 1;
      transform: none;
      align-self: center;
    }

    /* badge: linha 2 col 2-3 */
    .badge {
      grid-column: 2 / 4;
      grid-row: 2;
      justify-self: start;
      font-size: 10px;
      padding: 4px 8px;
    }

    /* descrição: oculta no mobile */
    .service-row-desc { display: none; }
  }
</style>
