---
// src/components/Footer.astro
const year = new Date().getFullYear();

const b = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const servicos = [
  { href: `${b}servicos/trafego-com-ia`, label: "Tráfego com IA" },
  { href: `${b}servicos/crm-automatizado`, label: "CRM Automatizado" },
  { href: `${b}servicos/agente-ia`, label: "Agente de IA 24h" },
  { href: `${b}servicos/omnichannel`, label: "Omnichannel" },
  { href: `${b}servicos/metricas`, label: "Métricas em Tempo Real" },
  { href: `${b}servicos/sites`, label: "Landing Pages" },
  { href: `${b}servicos/solucoes-comerciais`, label: "Soluções Comerciais" },
  { href: `${b}servicos/visualizacao-3d`, label: "3D / Realidade Aumentada" },
];

const empresa = [
  { href: `${b}sobre`, label: "Sobre nós" },
  { href: `${b}cases`, label: "Cases de sucesso" },
  { href: `${b}blog`, label: "Blog" },
  { href: `${b}contato`, label: "Diagnóstico gratuito" },
];
---

<footer class="footer-wrap">
  <!-- SVG gradient definitions -->
  <svg aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden">
    <defs>
      <linearGradient id="social-gold" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"   stop-color="#f7e98e"/>
        <stop offset="28%"  stop-color="#d4a843"/>
        <stop offset="55%"  stop-color="#8b6508"/>
        <stop offset="78%"  stop-color="#c99a2e"/>
        <stop offset="100%" stop-color="#f0d060"/>
      </linearGradient>
    </defs>
  </svg>

  <div class="footer-grid">
    <!-- Col 1: Brand -->
    <div class="footer-brand">
      <div class="wordmark">moveis<span>.pro</span></div>
      <p>Marketing pra móvel que vende pelo valor — não pelo preço.</p>

      <div class="footer-socials">
        <a href="https://www.instagram.com/_moveis.pro?igsh=OWlmZDJ2NzV4am43&utm_source=ig_contact_invite" class="footer-social" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="url(#social-gold)" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="/contato" class="footer-social" aria-label="Facebook">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="url(#social-gold)" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="/contato" class="footer-social" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="url(#social-gold)" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://wa.me/5583916706411" class="footer-social footer-wa" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="url(#social-gold)" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          <span class="footer-wa-wordmark">moveis<em>.pro</em></span>
        </a>
      </div>
    </div>

    <!-- Col 2: Sistema -->
    <nav class="footer-col" aria-label="Serviços">
      <h4>Sistema</h4>
      {servicos.map((s) => <a href={s.href}>{s.label}</a>)}
    </nav>

    <!-- Col 3: Empresa -->
    <nav class="footer-col" aria-label="Empresa">
      <h4>Empresa</h4>
      {empresa.map((e) => <a href={e.href}>{e.label}</a>)}
    </nav>

    <!-- Col 4: Contato -->
    <div class="footer-col footer-contact">
      <h4>Contato</h4>
      <p>Seg–Sex: 9h às 18h</p>
      <p>Sáb: 9h às 13h</p>
      <a href="https://wa.me/5583916706411" class="footer-wa-link" target="_blank" rel="noopener noreferrer">
        WhatsApp →
      </a>
      <a href={`${b}contato`} class="footer-diag-link">
        Diagnóstico gratuito →
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">© {year} Moveis.pro. Todos os direitos reservados.</p>
    <p class="footer-tagline">Feito com obsessão por resultado.</p>
  </div>
</footer>

<style>
  .footer-wrap {
    margin-top: 34px;
    border-top: 1px solid var(--line);
    padding: 48px 56px 32px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .wordmark {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 28px;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--cream);
    margin-bottom: 10px;
  }

  .wordmark span {
    color: var(--terra);
  }

  .footer-brand p {
    color: var(--text-muted);
    font-size: 13px;
    max-width: 300px;
    line-height: 1.55;
    margin-bottom: 18px;
  }

  .footer-socials {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .footer-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    text-decoration: none;
    background: rgba(247, 240, 232, 0.05);
    border: 1px solid rgba(212, 168, 67, 0.22);
    transition: background 0.22s ease, border-color 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
    flex-shrink: 0;
  }

  .footer-social svg {
    width: 16px;
    height: 16px;
    filter:
      drop-shadow(0 1px 0px rgba(247, 233, 142, 0.6))
      drop-shadow(0 0 6px rgba(212, 168, 67, 0.5))
      drop-shadow(0 0 16px rgba(212, 168, 67, 0.2));
    transition: filter 0.3s ease;
  }

  .footer-social:hover {
    background: rgba(212, 168, 67, 0.12);
    border-color: rgba(212, 168, 67, 0.55);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 168, 67, 0.18);
  }

  .footer-social.footer-wa {
    width: auto;
    padding: 0 12px 0 9px;
    border-radius: 999px;
    gap: 7px;
  }

  .footer-social.footer-wa svg {
    width: 17px;
    height: 17px;
  }

  .footer-wa-wordmark {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 15px;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    font-style: normal;
    background: linear-gradient(180deg, #f7e98e 0%, #d4a843 28%, #8b6508 55%, #c99a2e 78%, #f0d060 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-wa-wordmark em {
    font-style: normal;
  }

  /* Column links */
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-col h4 {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font-weight: 700;
    color: var(--terra);
    margin-bottom: 6px;
  }

  .footer-col a {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: var(--cream);
  }

  .footer-contact p {
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.5;
  }

  .footer-wa-link,
  .footer-diag-link {
    margin-top: 4px;
    font-weight: 600;
    color: var(--terra) !important;
  }

  .footer-diag-link {
    margin-top: 2px;
  }

  .footer-wa-link:hover,
  .footer-diag-link:hover {
    color: var(--terra-soft) !important;
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(247, 240, 232, 0.08);
    padding-top: 20px;
    margin-top: 36px;
  }

  .footer-copy {
    color: rgba(247, 240, 232, 0.4);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .footer-tagline {
    color: rgba(247, 240, 232, 0.3);
    font-size: 11px;
    letter-spacing: 0.03em;
    font-style: italic;
  }

  @media (max-width: 900px) {
    .footer-wrap {
      padding: 36px 24px 24px;
    }

    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 520px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .footer-brand {
      grid-column: 1;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 6px;
      align-items: flex-start;
    }
  }

