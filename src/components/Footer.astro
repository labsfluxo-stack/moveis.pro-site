---
// src/components/Footer.astro
const year = new Date().getFullYear();
const links = [
  { href: "/servicos", label: "Servicos" },
  { href: "/cases", label: "Cases" },
  { href: "/blog", label: "Blog" },
  { href: "/contato", label: "Contato" },
];
---

<footer class="footer-wrap">
  <div class="footer-brand">
    <div class="wordmark">moveis<span>.pro</span></div>
    <p>Marketing pra móvel que vende pelo valor — não pelo preço.</p>

    <a
      href="https://wa.me/5583916706411"
      class="footer-wa"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="WhatsApp Moveis.pro"
    >
      <!-- ícone WhatsApp com gradiente dourado metálico -->
      <svg class="footer-wa-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="wa-gold-footer" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%"   stop-color="#f5d980"/>
            <stop offset="45%"  stop-color="#d4a843"/>
            <stop offset="100%" stop-color="#8b6520"/>
          </linearGradient>
        </defs>
        <path fill="url(#wa-gold-footer)" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      <span>+55 83 9167-0641</span>
    </a>
  </div>

  <nav class="footer-links" aria-label="Rodape">
    {
      links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))
    }
  </nav>

  <p class="footer-copy">© {year} Moveis.pro. Todos os direitos reservados.</p>
</footer>

<style>
  .footer-wrap {
    margin-top: 34px;
    border-top: 1px solid var(--line);
    padding: 36px 56px 32px;
    display: grid;
    grid-template-columns: 1.4fr auto;
    gap: 20px;
    align-items: center;
  }

  .wordmark {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 30px;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--cream);
    margin-bottom: 8px;
  }

  .wordmark span {
    color: var(--terra);
  }

  .footer-brand p {
    color: var(--text-muted);
    font-size: 13px;
    max-width: 380px;
    line-height: 1.5;
    margin-bottom: 14px;
  }

  .footer-wa {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
  }

  .footer-wa:hover {
    color: var(--cream);
  }

  .footer-wa-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: flex-end;
  }

  .footer-links a {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .footer-links a:hover {
    color: var(--cream);
  }

  .footer-copy {
    grid-column: 1 / -1;
    color: rgba(247, 240, 232, 0.45);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-top: 1px solid rgba(247, 240, 232, 0.08);
    padding-top: 18px;
    margin-top: 2px;
  }

  @media (max-width: 860px) {
    .footer-wrap {
      grid-template-columns: 1fr;
      padding: 32px 24px 24px;
      gap: 16px;
    }

    .footer-links {
      justify-content: flex-start;
    }
  }
</style>
