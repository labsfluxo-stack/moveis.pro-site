---
// src/components/SectionHeader.astro
export interface Props {
  index: string;
  title: string;
  subtitle?: string;
  linkLabel?: string;
  linkHref?: string;
}

const { index, title, subtitle, linkLabel, linkHref } = Astro.props;
---

<div class="section-header shell">
  <div>
    <div class="kicker">
      <span class="kicker-line"></span>
      <span>{index}</span>
    </div>
    <h2>{title}</h2>
  </div>

  {(subtitle || linkLabel) && (
    <div class="summary">
      {subtitle && <p>{subtitle}</p>}
      {linkLabel && linkHref && (
        <a href={linkHref}>
          {linkLabel}
        </a>
      )}
    </div>
  )}
</div>

<style>
  .shell {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 34px;
    padding-bottom: 30px;
    border-bottom: 1px solid var(--line);
  }

  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    color: var(--terra);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .kicker-line {
    width: 30px;
    height: 1px;
    background: var(--terra);
    display: inline-block;
  }

  h2 {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: clamp(34px, 4.2vw, 56px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    color: var(--cream);
    white-space: pre-line;
  }

  .summary {
    max-width: 380px;
    text-align: right;
  }

  .summary p {
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .summary a {
    text-decoration: none;
    color: var(--terra);
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .summary a::after {
    content: "->";
    font-size: 12px;
  }

  @media (max-width: 980px) {
    .summary {
      text-align: left;
      max-width: 100%;
    }
  }
</style>
