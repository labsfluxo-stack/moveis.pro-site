---
const links = [
  { href: "/servicos", label: "Servicos" },
  { href: "/sobre", label: "Sobre" },
  { href: "/cases", label: "Cases" },
  { href: "/blog", label: "Blog" },
  { href: "/contato", label: "Contato" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="Ir para inicio">
      <span class="brand-icon">m<span>.</span></span>
      <span class="brand-text">moveis<span>.pro</span></span>
    </a>

    <ul class="nav-links hidden lg:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${isActive(link.href) ? "is-active" : ""}`}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="hidden lg:flex items-center gap-3">
      <a href="/cases" class="nav-ghost">Ver resultados</a>
      <a href="/contato" class="nav-cta">Diagnostico gratuito</a>
    </div>

    <button
      id="nav-toggle"
      class="nav-toggle lg:hidden"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<div id="mobile-backdrop" class="mobile-backdrop"></div>

<aside id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <div class="mobile-top">
    <span class="mobile-title">Menu</span>
    <button id="nav-close" class="mobile-close" aria-label="Fechar menu" type="button">Fechar</button>
  </div>

  <ul class="mobile-links">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class={`mobile-link ${isActive(link.href) ? "is-active" : ""}`}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

</aside>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 58;
    padding: 14px 14px 0;
  }

  .nav-inner {
    max-width: 1220px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 9px 12px;
    border-radius: 14px;
    border: 1px solid var(--line);
    background: rgba(16, 12, 9, 0.45);
    backdrop-filter: blur(16px) saturate(1.25);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .brand-icon {
    width: 33px;
    height: 33px;
    border-radius: 8px;
    border: 1.6px solid rgba(247, 240, 232, 0.35);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 16px;
    font-weight: 900;
    line-height: 1;
    color: var(--cream);
    letter-spacing: -0.03em;
  }

  .brand-icon span {
    color: var(--terra);
  }

  .brand-text {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 21px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--cream);
  }

  .brand-text span {
    color: var(--terra);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    list-style: none;
  }

  .nav-link {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--cream);
  }

  .nav-ghost,
  .nav-cta {
    text-decoration: none;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    border-radius: 999px;
    padding: 10px 16px;
    white-space: nowrap;
  }

  .nav-ghost {
    color: var(--text-dim);
    border: 1px solid var(--line-strong);
    background: rgba(247, 240, 232, 0.02);
  }

  .nav-ghost:hover {
    color: var(--cream);
    border-color: rgba(247, 240, 232, 0.35);
  }

  .nav-cta {
    color: var(--cream);
    border: 1px solid rgba(247, 240, 232, 0.26);
    background: linear-gradient(135deg, var(--terra-deep), var(--terra));
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.3);
  }

  .nav-cta:hover {
    transform: translateY(-1px);
  }

  .nav-toggle {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    border: 1px solid var(--line-strong);
    background: rgba(247, 240, 232, 0.03);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
  }

  .nav-toggle span {
    width: 18px;
    height: 1.8px;
    border-radius: 2px;
    background: var(--cream);
    display: block;
    transform-origin: center;
  }

  .nav-toggle.is-open span:nth-child(1) {
    transform: translateY(6.8px) rotate(45deg);
  }
  .nav-toggle.is-open span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle.is-open span:nth-child(3) {
    transform: translateY(-6.8px) rotate(-45deg);
  }

  .mobile-backdrop {
    display: none;
  }

  .mobile-menu {
    position: fixed;
    top: 90px;
    left: auto;
    right: 14px;
    z-index: 57;
    padding: 4px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(16, 12, 9, 0.96);
    backdrop-filter: blur(20px);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.18s ease, transform 0.18s ease;
    display: flex;
    flex-direction: column;
    width: fit-content;
    min-width: 160px;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mobile-top {
    display: none;
  }

  .mobile-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-link {
    text-decoration: none;
    color: var(--text-muted);
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.03em;
    display: block;
  }

  .mobile-link.is-active,
  .mobile-link:hover {
    color: var(--cream);
    background: rgba(247, 240, 232, 0.06);
  }


  @media (min-width: 768px) {
    .site-nav {
      padding: 16px 24px 0;
    }
    .nav-inner {
      padding: 9px 14px;
    }
  }

  @media (min-width: 1080px) {
    .site-nav {
      padding-top: 18px;
    }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const closeButton = document.getElementById("nav-close");
  const menu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("mobile-backdrop");

  let open = false;

  const setMenuState = (nextOpen) => {
    open = nextOpen;
    toggle?.classList.toggle("is-open", open);
    menu?.classList.toggle("is-open", open);
    backdrop?.classList.toggle("is-open", open);
    toggle?.setAttribute("aria-expanded", String(open));
    menu?.setAttribute("aria-hidden", String(!open));
  };

  toggle?.addEventListener("click", () => setMenuState(!open));
  closeButton?.addEventListener("click", () => setMenuState(false));
  backdrop?.addEventListener("click", () => setMenuState(false));

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && open) {
      setMenuState(false);
    }
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenuState(false));
  });
</script>
