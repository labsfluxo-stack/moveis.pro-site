---
const b = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const links = [
  { href: `${b}servicos`, label: "Servicos" },
  { href: `${b}sobre`, label: "Sobre" },
  { href: `${b}cases`, label: "Cases" },
  { href: `${b}blog`, label: "Blog" },
  { href: `${b}contato`, label: "Contato" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === b ? currentPath === b || currentPath === "/" : currentPath.startsWith(href);
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href={b} class="brand" aria-label="Ir para inicio">
      <span class="brand-icon">m<span>.</span></span>
      <span class="brand-text">moveis<span>.pro</span></span>
    </a>

    <ul class="nav-links hidden lg:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${isActive(link.href) ? "is-active" : ""}`}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="hidden lg:flex items-center gap-3">
      <a href={`${b}cases`} class="nav-ghost">Ver resultados</a>
      <a href={`${b}contato`} class="nav-cta">Diagnostico gratuito</a>
    </div>

    <!-- mobile: links visíveis + hamburguer -->
    <div class="mobile-actions lg:hidden">
      <a href={`${b}servicos`} class="mobile-nav-link">Serviços</a>
      <a href={`${b}contato`} class="mobile-nav-link mobile-nav-link--cta">Contato</a>
      <button
        id="nav-toggle"
        class="nav-toggle"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div id="mobile-backdrop" class="mobile-backdrop"></div>

<aside id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <ul class="mobile-links">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class={`mobile-link ${isActive(link.href) ? "is-active" : ""}`}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
  <div class="mobile-menu-footer">
    <a href={`${b}contato`} class="mobile-menu-cta">Diagnóstico gratuito →</a>
  </div>
</aside>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 58;
    padding: 14px 14px 0;
  }

  .nav-inner {
    max-width: 1220px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 9px 12px;
    border-radius: 14px;
    border: 1px solid var(--line);
    background: rgba(16, 12, 9, 0.45);
    backdrop-filter: blur(16px) saturate(1.25);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .brand-icon {
    width: 33px;
    height: 33px;
    border-radius: 8px;
    border: 1.6px solid rgba(247, 240, 232, 0.35);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 16px;
    font-weight: 900;
    line-height: 1;
    color: var(--cream);
    letter-spacing: -0.03em;
  }

  .brand-icon span {
    color: var(--terra);
  }

  .brand-text {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 21px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--cream);
  }

  .brand-text span {
    color: var(--terra);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    list-style: none;
  }

  .nav-link {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--cream);
  }

  .nav-ghost,
  .nav-cta {
    text-decoration: none;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    border-radius: 999px;
    padding: 10px 16px;
    white-space: nowrap;
  }

  .nav-ghost {
    color: var(--text-dim);
    border: 1px solid var(--line-strong);
    background: rgba(247, 240, 232, 0.02);
  }

  .nav-ghost:hover {
    color: var(--cream);
    border-color: rgba(247, 240, 232, 0.35);
  }

  .nav-cta {
    color: var(--cream);
    border: 1px solid rgba(247, 240, 232, 0.26);
    background: linear-gradient(135deg, var(--terra-deep), var(--terra));
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.3);
  }

  .nav-cta:hover {
    transform: translateY(-1px);
  }

  .nav-toggle {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    border: 1px solid var(--line-strong);
    background: rgba(247, 240, 232, 0.03);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
  }

  .nav-toggle span {
    width: 18px;
    height: 1.8px;
    border-radius: 2px;
    background: var(--cream);
    display: block;
    transform-origin: center;
  }

  .nav-toggle.is-open span:nth-child(1) {
    transform: translateY(6.8px) rotate(45deg);
  }
  .nav-toggle.is-open span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle.is-open span:nth-child(3) {
    transform: translateY(-6.8px) rotate(-45deg);
  }

  /* ── MOBILE ACTIONS (CTA + hamburguer) ── */
  .mobile-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mobile-nav-link {
    text-decoration: none;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 7px 10px;
    border-radius: 8px;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .mobile-nav-link:hover {
    color: var(--cream);
  }

  .mobile-nav-link--cta {
    color: var(--terra);
    border: 1px solid rgba(200, 121, 42, 0.35);
    background: rgba(200, 121, 42, 0.08);
  }

  .mobile-nav-link--cta:hover {
    color: var(--cream);
    background: rgba(200, 121, 42, 0.18);
  }

  .mobile-backdrop {
    display: none;
  }

  /* ── MOBILE DROPDOWN ── */
  .mobile-menu {
    position: fixed;
    top: 76px;
    right: 14px;
    left: 14px;
    z-index: 57;
    padding: 6px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: rgba(12, 9, 6, 0.97);
    backdrop-filter: blur(24px);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px) scale(0.98);
    transform-origin: top right;
    transition: opacity 0.2s ease, transform 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .mobile-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 4px 0;
  }

  .mobile-link {
    text-decoration: none;
    color: var(--text-muted);
    padding: 11px 14px;
    border-radius: 9px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.03em;
    display: block;
    transition: background 0.15s, color 0.15s;
  }

  .mobile-link.is-active,
  .mobile-link:hover {
    color: var(--cream);
    background: rgba(247, 240, 232, 0.07);
  }

  .mobile-menu-footer {
    border-top: 1px solid var(--line);
    padding: 10px 6px 4px;
    margin-top: 2px;
  }

  .mobile-menu-cta {
    display: block;
    text-align: center;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--cream);
    background: linear-gradient(135deg, var(--terra-deep), var(--terra));
    border-radius: 9px;
    padding: 13px 16px;
  }


  @media (min-width: 768px) {
    .site-nav {
      padding: 16px 24px 0;
    }
    .nav-inner {
      padding: 9px 14px;
    }
  }

  @media (min-width: 1080px) {
    .site-nav {
      padding-top: 18px;
    }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const closeButton = document.getElementById("nav-close");
  const menu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("mobile-backdrop");

  let open = false;

  const setMenuState = (nextOpen) => {
    open = nextOpen;
    toggle?.classList.toggle("is-open", open);
    menu?.classList.toggle("is-open", open);
    backdrop?.classList.toggle("is-open", open);
    toggle?.setAttribute("aria-expanded", String(open));
    menu?.setAttribute("aria-hidden", String(!open));
  };

  toggle?.addEventListener("click", () => setMenuState(!open));
  closeButton?.addEventListener("click", () => setMenuState(false));
  backdrop?.addEventListener("click", () => setMenuState(false));

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && open) {
      setMenuState(false);
    }
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenuState(false));
  });
</script>
