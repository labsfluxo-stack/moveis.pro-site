---
const links = [
  { href: '/servicos', label: 'Serviços' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/cases', label: 'Cases' },
  { href: '/blog', label: 'Blog' },
  { href: '/contato', label: 'Contato' },
];

const currentPath = Astro.url.pathname;
---

<nav
  class="fixed top-0 left-0 right-0 z-50 h-16 px-6 md:px-14 flex items-center justify-between"
  style="background: rgba(7,7,7,0.88); backdrop-filter: blur(18px) saturate(1.6); border-bottom: 1px solid var(--border);"
>
  <a href="/" class="nav-logo no-underline flex items-center gap-2">
    <img src="/logo.png" alt="Moveis.pro logo" class="nav-logo-img" />
    <span class="nav-logo-text">
      <span class="nav-logo-oveis">oveis</span><span class="nav-logo-dotpro">.pro</span>
    </span>
  </a>

  <!-- Desktop links -->
  <ul class="hidden md:flex gap-9 list-none">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class={`text-sm font-normal no-underline transition-colors duration-150 ${
            currentPath.startsWith(link.href) ? 'text-white' : 'hover:text-white'
          }`}
          style={currentPath.startsWith(link.href) ? '' : 'color: var(--muted);'}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Desktop CTA -->
  <a
    href="/contato"
    class="hidden md:inline-flex text-sm font-semibold text-white px-5 py-2.5 rounded-lg no-underline transition-opacity hover:opacity-90"
    style="background: var(--brown);"
  >
    Falar com especialista
  </a>

  <!-- Mobile hamburger -->
  <button
    id="nav-toggle"
    class="md:hidden flex flex-col gap-1.5 p-2"
    aria-label="Abrir menu"
  >
    <span class="block w-6 h-0.5 bg-white transition-all duration-200" id="bar1"></span>
    <span class="block w-6 h-0.5 bg-white transition-all duration-200" id="bar2"></span>
    <span class="block w-6 h-0.5 bg-white transition-all duration-200" id="bar3"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 flex flex-col pt-16 px-6 pb-10 md:hidden"
  style="background: var(--dark); display: none;"
>
  <ul class="flex flex-col gap-1 mt-8 list-none flex-1">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class="block py-4 text-lg font-semibold no-underline transition-colors hover:text-white"
          style={`color: ${currentPath.startsWith(link.href) ? '#fff' : 'var(--muted)'}; border-bottom: 1px solid var(--border);`}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
  <a
    href="/contato"
    class="flex items-center justify-center text-sm font-semibold text-white rounded-[10px] no-underline mt-8"
    style="background: var(--brown); padding: 16px;"
  >
    Falar com especialista →
  </a>
</div>

<style>
  .nav-logo-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(200,121,42,0.5));
    transition: filter 0.3s;
  }
  .nav-logo:hover .nav-logo-img {
    filter: drop-shadow(0 0 14px rgba(200,121,42,0.85));
  }

  .nav-logo-text {
    font-family: 'Urbanist', sans-serif;
    font-weight: 900;
    font-size: 20px;
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .nav-logo-oveis {
    color: #fff;
    position: relative;
  }

  .nav-logo-dotpro {
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 50%, var(--brown) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    animation: logo-shimmer 3s ease infinite;
  }

  @keyframes logo-shimmer {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .nav-logo:hover .nav-logo-oveis {
    color: rgba(255,255,255,0.85);
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    if (menu) menu.style.display = open ? 'flex' : 'none';
    if (bar1) bar1.style.transform = open ? 'translateY(8px) rotate(45deg)' : '';
    if (bar2) bar2.style.opacity = open ? '0' : '1';
    if (bar3) bar3.style.transform = open ? 'translateY(-8px) rotate(-45deg)' : '';
  });

  // Close menu on link click
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      open = false;
      if (menu) menu.style.display = 'none';
      if (bar1) bar1.style.transform = '';
      if (bar2) bar2.style.opacity = '1';
      if (bar3) bar3.style.transform = '';
    });
  });
</script>
