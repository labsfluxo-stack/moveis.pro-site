---
// src/components/HeroCard.astro
export interface Props {
  metric: string;
  metricLabel: string;
  barPercent: number;
  rows: Array<{ label: string; value: string }>;
}

const { metric, metricLabel, barPercent, rows } = Astro.props;
---

<div class="hero-panel">
  <div class="panel-top">
    <span class="panel-kicker">Painel Moveis.pro</span>
    <span class="panel-tag">Atualizado agora</span>
  </div>

  <div class="panel-metric">
    <em>{metric.startsWith("+") ? "+" : ""}</em>{metric.replace("+", "")}
  </div>
  <p class="panel-label">{metricLabel}</p>

  <div class="panel-progress">
    <div class="panel-progress-fill" style={`width: ${barPercent}%;`}></div>
  </div>

  <div class="panel-rows">
    {
      rows.map((row) => (
        <div class="panel-row">
          <span>{row.label}</span>
          <b>{row.value}</b>
        </div>
      ))
    }
  </div>
</div>

<style>
  .hero-panel {
    position: relative;
    border-radius: 22px;
    padding: 24px 22px 20px;
    border: 1px solid var(--line);
    background:
      radial-gradient(circle at 100% 0%, rgba(184, 92, 58, 0.25) 0%, transparent 42%),
      linear-gradient(165deg, rgba(247, 240, 232, 0.03) 0%, rgba(247, 240, 232, 0.01) 100%);
    box-shadow: var(--card-shadow);
    overflow: hidden;
  }

  .hero-panel::before {
    content: "";
    position: absolute;
    left: 14px;
    right: 14px;
    top: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(205, 125, 94, 0.95),
      transparent
    );
  }

  .panel-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 14px;
  }

  .panel-kicker {
    color: var(--text-dim);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .panel-tag {
    padding: 5px 9px;
    border-radius: 999px;
    border: 1px solid rgba(247, 240, 232, 0.23);
    color: var(--text-muted);
    font-size: 9px;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .panel-metric {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 54px;
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--cream);
  }

  .panel-metric em {
    font-style: normal;
    color: var(--terra);
  }

  .panel-label {
    color: var(--text-muted);
    font-size: 12px;
    line-height: 1.45;
    margin-top: 8px;
    margin-bottom: 16px;
  }

  .panel-progress {
    width: 100%;
    height: 7px;
    border-radius: 999px;
    background: rgba(247, 240, 232, 0.08);
    overflow: hidden;
    margin-bottom: 16px;
  }

  .panel-progress-fill {
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--terra-deep), var(--terra-soft));
  }

  .panel-rows {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .panel-row {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    border-top: 1px solid rgba(247, 240, 232, 0.08);
    padding-top: 10px;
  }

  .panel-row span {
    color: var(--text-muted);
    font-size: 11px;
    line-height: 1.35;
  }

  .panel-row b {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 15px;
    font-weight: 800;
    color: var(--terra);
    letter-spacing: -0.02em;
    white-space: nowrap;
  }
</style>
