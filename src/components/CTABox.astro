---
// src/components/CTABox.astro
export interface Props {
  title: string;
  subtitle: string;
  buttonLabel: string;
  buttonHref: string;
}

const { title, subtitle, buttonLabel, buttonHref } = Astro.props;
const titleLines = title.split("\n");
---

<section class="cta-wrap">
  <div class="cta-grid">
    <div>
      <h2>
        {
          titleLines.map((line, i) => (
            <span>
              {i === titleLines.length - 1 ? <em>{line}</em> : line}
              {i < titleLines.length - 1 && <br />}
            </span>
          ))
        }
      </h2>
      <ul>
        <li>Setup pratico em 14 dias</li>
        <li>Primeiras metas em 45 dias</li>
        <li>Atendimento com especialista de nicho</li>
      </ul>
    </div>

    <div class="cta-side">
      <p>{subtitle}</p>
      <a href={buttonHref}>{buttonLabel}</a>
    </div>
  </div>
</section>

<style>
  .cta-wrap {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--line);
    background:
      radial-gradient(circle at 100% 100%, rgba(205, 125, 94, 0.2) 0%, transparent 40%),
      radial-gradient(circle at 0% 0%, rgba(184, 92, 58, 0.2) 0%, transparent 46%),
      rgba(247, 240, 232, 0.025);
    padding: 50px 46px;
    box-shadow: var(--card-shadow);
  }

  .cta-grid {
    display: grid;
    gap: 44px;
    align-items: center;
    grid-template-columns: 1fr 290px;
  }

  h2 {
    color: var(--cream);
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: clamp(34px, 4.4vw, 58px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin-bottom: 22px;
  }

  h2 em {
    color: var(--terra);
    font-style: normal;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 10px;
    list-style: none;
  }

  li {
    color: var(--text-dim);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid rgba(247, 240, 232, 0.22);
    border-radius: 999px;
    padding: 7px 10px;
    background: rgba(247, 240, 232, 0.03);
  }

  .cta-side p {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .cta-side a {
    display: inline-flex;
    justify-content: center;
    width: 100%;
    text-decoration: none;
    color: var(--cream);
    background: linear-gradient(135deg, var(--terra-deep), var(--terra));
    border: 1px solid rgba(247, 240, 232, 0.26);
    border-radius: 12px;
    padding: 15px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cta-side a:hover {
    transform: translateY(-1px);
  }

  @media (max-width: 980px) {
    .cta-wrap {
      padding: 34px 24px;
    }
  }
</style>
