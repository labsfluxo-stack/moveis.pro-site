---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const enviado = Astro.url.searchParams.get("enviado") === "1";
---

<BaseLayout
  title="Diagnóstico gratuito — Moveis.pro"
  description="20 minutos de conversa. A gente mapeia onde sua loja está vazando lead e te entrega um plano prático. Pago ou não."
>
  <Nav />
  <main style="padding-top: 64px;">
    {enviado ? (
      <section class="success-wrap">
        <div class="success-card">
          <span class="success-icon">OK</span>
          <h1>Recebido.</h1>
          <p>A gente retorna em até 24h úteis pra agendar o diagnóstico. Se der vontade de adiantar, chama no WhatsApp.</p>
          <a href="/">← Voltar pra home</a>
        </div>
      </section>
    ) : (
      <>
        <section class="hero">
          <div class="hero-glow"></div>
          <div class="hero-inner">
            <div class="eyebrow">
              <span class="line"></span>
              <span>Diagnóstico gratuito</span>
            </div>

            <h1>
              45 dias pra encher
              <br />
              seu showroom de
              <br />
              <em>cliente qualificado.</em>
            </h1>

            <p>
              20 minutos de conversa. A gente mapeia o gargalo da sua loja —
              captação, atendimento ou follow-up — e te entrega um plano prático.
              Pago ou não.
            </p>
          </div>
        </section>

        <section class="contato-grid">
          <aside class="left">
            <div class="card">
              <p class="card-kicker">O que você sai com</p>
              <ul>
                <li>Diagnóstico honesto da sua operação atual</li>
                <li>Onde está vazando lead e faturamento</li>
                <li>Prioridade pros próximos 14 dias</li>
                <li>Plano prático pra meta em 45 dias</li>
              </ul>
            </div>

            <div class="card">
              <p class="card-kicker">Garantia comercial</p>
              <h2>Mínimo de 30 leads qualificados com CPL ≤ R$100 no primeiro ciclo.</h2>
              <p class="small">
                Se a gente não entregar, o segundo mês é por nossa conta. Simples
                assim — se não vender, a gente não dorme.
              </p>
            </div>

            <div class="mini-grid">
              <div>
                <b>14 dias</b>
                <span>setup</span>
              </div>
              <div>
                <b>45 dias</b>
                <span>showroom cheio</span>
              </div>
              <div>
                <b>30 leads</b>
                <span>garantidos</span>
              </div>
            </div>
          </aside>

          <section class="form-card" aria-label="Formulário de contato">
            <p class="form-kicker">Conta pra gente</p>

            <form action="https://formspree.io/f/SEU_FORM_ID" method="POST" class="form">
              <input type="hidden" name="_gotcha" style="display:none" />
              <input type="hidden" name="_next" value="https://moveis.pro/contato?enviado=1" />

              <label>
                <span>Seu nome *</span>
                <input type="text" name="nome" required />
              </label>

              <label>
                <span>Nome da loja *</span>
                <input type="text" name="loja" required />
              </label>

              <div class="row">
                <label>
                  <span>Cidade *</span>
                  <input type="text" name="cidade" required />
                </label>
                <label>
                  <span>WhatsApp *</span>
                  <input type="tel" name="whatsapp" required />
                </label>
              </div>

              <label>
                <span>Ticket médio da loja *</span>
                <select name="ticket" required>
                  <option value="" disabled selected>Selecione</option>
                  <option value="ate-3k">Até R$3 mil</option>
                  <option value="3k-8k">R$3 mil a R$8 mil</option>
                  <option value="8k-15k">R$8 mil a R$15 mil (médio)</option>
                  <option value="15k-plus">Acima de R$15 mil (alto)</option>
                </select>
              </label>

              <label>
                <span>Onde está travando hoje? *</span>
                <select name="desafio" required>
                  <option value="" disabled selected>Selecione</option>
                  <option value="lead">Não chega lead qualificado</option>
                  <option value="followup">Vendedor perde venda por falta de follow-up</option>
                  <option value="atendimento">Demora pra responder WhatsApp / Instagram</option>
                  <option value="gestao">Não sei o que está funcionando no marketing</option>
                  <option value="preco">Cliente entra só pra pechinchar</option>
                </select>
              </label>

              <label>
                <span>Quer contar mais algo? (opcional)</span>
                <textarea name="mensagem" rows="4" placeholder="Fique à vontade — quanto mais contexto, mais afiado o diagnóstico."></textarea>
              </label>

              <button type="submit">Quero o diagnóstico gratuito →</button>
            </form>
          </section>
        </section>
      </>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding: 88px 56px 26px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -120px;
    right: -80px;
    width: 460px;
    height: 460px;
    background: radial-gradient(circle, rgba(184, 92, 58, 0.18) 0%, transparent 68%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 860px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    color: var(--gold);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .line {
    width: 30px;
    height: 1px;
    background: var(--gold);
    display: block;
  }

  h1 {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: clamp(44px, 6vw, 84px);
    letter-spacing: -0.05em;
    line-height: 0.93;
    color: #fff;
    margin-bottom: 16px;
  }

  h1 em {
    font-style: normal;
    color: var(--gold);
  }

  .hero p {
    max-width: 620px;
    color: var(--dim);
    font-size: 16px;
    line-height: 1.7;
  }

  .contato-grid {
    padding: 44px 56px 100px;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 48px;
    align-items: start;
  }

  .left {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card {
    border: 1px solid var(--border);
    background: rgba(247, 240, 232, 0.02);
    border-radius: 18px;
    padding: 22px;
  }

  .card-kicker {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: var(--gold);
    font-weight: 700;
    margin-bottom: 12px;
  }

  .card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .card li {
    position: relative;
    color: var(--dim);
    font-size: 14px;
    line-height: 1.5;
    padding-left: 14px;
  }

  .card li::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: var(--gold);
    position: absolute;
    top: 7px;
    left: 0;
    transform: rotate(45deg);
  }

  .card h2 {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: clamp(22px, 3.2vw, 32px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 9px;
  }

  .small {
    color: var(--muted);
    font-size: 13px;
    line-height: 1.6;
  }

  .mini-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .mini-grid > div {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--dark-3);
    padding: 12px;
  }

  .mini-grid b {
    display: block;
    color: var(--gold);
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 24px;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 4px;
  }

  .mini-grid span {
    color: var(--muted);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .form-card {
    border: 1px solid var(--border);
    border-radius: 22px;
    background: var(--dark-3);
    padding: 28px;
  }

  .form-kicker {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: var(--gold);
    font-weight: 700;
    margin-bottom: 16px;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form label span {
    color: var(--text-muted);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .form input,
  .form select,
  .form textarea {
    width: 100%;
    border: 1px solid rgba(247, 240, 232, 0.18);
    border-radius: 10px;
    background: rgba(247, 240, 232, 0.02);
    color: #fff;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    padding: 12px;
  }

  .form textarea {
    resize: vertical;
    min-height: 90px;
  }

  .row {
    display: grid;
    gap: 10px;
    grid-template-columns: 1fr 1fr;
  }

  .form button {
    margin-top: 6px;
    border: 1px solid rgba(247, 240, 232, 0.26);
    border-radius: 10px;
    background: linear-gradient(135deg, var(--brown), var(--gold));
    color: #fff;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-weight: 800;
    padding: 14px;
    cursor: pointer;
  }

  .form button:hover {
    opacity: 0.92;
  }

  .success-wrap {
    min-height: calc(100vh - 64px);
    display: grid;
    place-items: center;
    padding: 30px;
  }

  .success-card {
    width: min(92vw, 520px);
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--dark-3);
    padding: 30px;
    text-align: center;
  }

  .success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    border-radius: 999px;
    border: 1px solid rgba(247, 240, 232, 0.26);
    color: var(--gold);
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }

  .success-card h1 {
    font-size: clamp(30px, 4.4vw, 46px);
    margin-bottom: 8px;
  }

  .success-card p {
    color: var(--dim);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .success-card a {
    display: inline-flex;
    text-decoration: none;
    color: #fff;
    padding: 12px 16px;
    border-radius: 10px;
    border: 1px solid rgba(247, 240, 232, 0.26);
    background: linear-gradient(135deg, var(--brown), var(--gold));
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 800;
  }

  @media (max-width: 920px) {
    .contato-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 34px 24px 84px;
    }

    .hero {
      padding: 72px 24px 16px;
    }

    .row,
    .mini-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
