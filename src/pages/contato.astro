---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Marquee from "../components/Marquee.astro";

const b = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const enviado = Astro.url.searchParams.get("enviado") === "1";

const marqueeItems = [
  "Diagnóstico honesto da operação",
  "Onde está vazando lead",
  "Prioridade pros próximos 14 dias",
  "Plano prático pra meta em 45 dias",
  "Mínimo 30 leads qualificados",
  "Setup em 14 dias",
];
---

<BaseLayout
  title="Diagnóstico gratuito — Moveis.pro"
  description="20 minutos de conversa. A gente mapeia onde sua loja está vazando lead e te entrega um plano prático. Pago ou não."
>
  <Nav />
  <main>
    {enviado ? (
      <section class="success-wrap">
        <div class="success-card">
          <span class="success-icon">OK</span>
          <h1>Recebido.</h1>
          <p>A gente retorna em até 24h úteis pra agendar o diagnóstico. Se der vontade de adiantar, chama no WhatsApp.</p>
          <a href={import.meta.env.BASE_URL}>← Voltar pra home</a>
        </div>
      </section>
    ) : (
      <>
        <!-- ① HERO CINEMATIC -->
        <section class="hero" id="contato-hero">
          <!-- vídeo de fundo -->
          <video
            id="contato-video"
            class="hero-media hero-video"
            autoplay
            muted
            playsinline
            preload="auto"
            poster={`${b}images/contato.png`}
          >
            <source src={`${b}videos/contato.mp4`} type="video/mp4" />
          </video>

          <!-- imagem de fallback (sempre visível em background) -->
          <img
            id="contato-poster"
            class="hero-media hero-poster"
            src={`${b}images/contato.png`}
            alt=""
          />

          <!-- overlays de legibilidade -->
          <div class="hero-vignette"></div>
          <div class="hero-gradient"></div>

          <!-- conteúdo -->
          <div class="hero-inner">
            <div class="eyebrow">
              <span class="line"></span>
              <span>Diagnóstico gratuito</span>
            </div>

            <h1>
              45 dias pra encher
              <br />
              seu showroom de
              <br />
              <em>cliente qualificado.</em>
            </h1>

            <p>
              20 minutos de conversa. A gente mapeia o gargalo da sua loja —
              captação, atendimento ou follow-up — e te entrega um plano prático.
              Pago ou não.
            </p>
          </div>
        </section>

        <!-- ② MARQUEE — sobreposto na base da hero -->
        <div class="marquee-bridge">
          <Marquee items={marqueeItems} />
        </div>

        <!-- ③ GRID: cards + formulário -->
        <section class="contato-grid">
          <aside class="left">
            <div class="card">
              <p class="card-kicker">O que você sai com</p>
              <ul>
                <li>Diagnóstico honesto da sua operação atual</li>
                <li>Onde está vazando lead e faturamento</li>
                <li>Prioridade pros próximos 14 dias</li>
                <li>Plano prático pra meta em 45 dias</li>
              </ul>
            </div>

            <div class="card">
              <p class="card-kicker">Garantia comercial</p>
              <h2>Mínimo de 30 leads qualificados com CPL ≤ R$100 no primeiro ciclo.</h2>
              <p class="small">
                Se a gente não entregar, o segundo mês é por nossa conta. Simples
                assim — se não vender, a gente não dorme.
              </p>
            </div>

            <div class="mini-grid">
              <div>
                <b>14 dias</b>
                <span>setup</span>
              </div>
              <div>
                <b>45 dias</b>
                <span>showroom cheio</span>
              </div>
              <div>
                <b>30 leads</b>
                <span>garantidos</span>
              </div>
            </div>
          </aside>

          <section class="form-card" aria-label="Formulário de contato">
            <p class="form-kicker">Conta pra gente</p>

            <form action="https://formspree.io/f/SEU_FORM_ID" method="POST" class="form">
              <input type="hidden" name="_gotcha" style="display:none" />
              <input type="hidden" name="_next" value="https://moveis.pro/contato?enviado=1" />

              <label>
                <span>Seu nome *</span>
                <input type="text" name="nome" required />
              </label>

              <label>
                <span>Nome da loja *</span>
                <input type="text" name="loja" required />
              </label>

              <div class="row">
                <label>
                  <span>Cidade *</span>
                  <input type="text" name="cidade" required />
                </label>
                <label>
                  <span>WhatsApp *</span>
                  <input type="tel" name="whatsapp" required />
                </label>
              </div>

              <label>
                <span>Ticket médio da loja *</span>
                <select name="ticket" required>
                  <option value="" disabled selected>Selecione</option>
                  <option value="ate-3k">Até R$3 mil</option>
                  <option value="3k-8k">R$3 mil a R$8 mil</option>
                  <option value="8k-15k">R$8 mil a R$15 mil (médio)</option>
                  <option value="15k-plus">Acima de R$15 mil (alto)</option>
                </select>
              </label>

              <label>
                <span>Onde está travando hoje? *</span>
                <select name="desafio" required>
                  <option value="" disabled selected>Selecione</option>
                  <option value="lead">Não chega lead qualificado</option>
                  <option value="followup">Vendedor perde venda por falta de follow-up</option>
                  <option value="atendimento">Demora pra responder WhatsApp / Instagram</option>
                  <option value="gestao">Não sei o que está funcionando no marketing</option>
                  <option value="preco">Cliente entra só pra pechinchar</option>
                </select>
              </label>

              <label>
                <span>Quer contar mais algo? (opcional)</span>
                <textarea name="mensagem" rows="4" placeholder="Fique à vontade — quanto mais contexto, mais afiado o diagnóstico."></textarea>
              </label>

              <button type="submit">Quero o diagnóstico gratuito →</button>
            </form>
          </section>
        </section>
      </>
    )}
  </main>
  <Footer />
</BaseLayout>

<script>
  const heroEl    = document.getElementById('contato-hero') as HTMLElement | null;
  const videoEl   = document.getElementById('contato-video') as HTMLVideoElement | null;

  if (heroEl && videoEl) {
    videoEl.addEventListener('playing', () => {
      heroEl.classList.add('playing');
      heroEl.classList.remove('finished');
    });
    videoEl.addEventListener('ended', () => {
      heroEl.classList.remove('playing');
      heroEl.classList.add('finished');
    });
    videoEl.play().catch(() => {});
  }
</script>

<style>
  /* ── HERO CINEMATIC ── */
  .hero {
    position: relative;
    width: 100%;
    height: 92vh;
    min-height: 650px;
    max-height: 900px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
    z-index: 0;
  }

  /* poster: always visible as base layer */
  .hero-poster {
    z-index: 0;
    opacity: 1;
    animation: hero-zoom 24s ease-in-out infinite alternate;
  }

  /* video: hidden until playing */
  .hero-video {
    z-index: 1;
    opacity: 0;
    transition: opacity 1.2s ease;
  }

  .hero.playing .hero-video  { opacity: 1; }
  .hero.finished .hero-video { opacity: 0; pointer-events: none; }

  @keyframes hero-zoom {
    from { transform: scale(1.02); }
    to   { transform: scale(1.07); }
  }

  /* vinheta radial */
  .hero-vignette {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: radial-gradient(ellipse 110% 90% at 30% 55%, transparent 0%, rgba(7,7,7,0.45) 65%, rgba(7,7,7,0.88) 100%);
  }

  /* gradiente: escurece topo (texto) + lateral esquerda + base suave */
  .hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background:
      linear-gradient(to right, rgba(7,7,7,0.94) 0%, rgba(7,7,7,0.72) 30%, rgba(7,7,7,0.28) 58%, transparent 80%),
      linear-gradient(to bottom, rgba(7,7,7,0.55) 0%, rgba(7,7,7,0.2) 35%, rgba(7,7,7,0.5) 72%, var(--dark) 100%);
  }

  /* conteúdo sobreposto */
  .hero-inner {
    position: relative;
    z-index: 5;
    max-width: 1400px;
    width: 100%;
    padding: 140px 56px 60px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    color: var(--gold);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .line {
    width: 30px;
    height: 1px;
    background: var(--gold);
    display: block;
  }

  h1 {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: clamp(44px, 6vw, 84px);
    letter-spacing: -0.05em;
    line-height: 0.93;
    color: #fff;
    margin-bottom: 16px;
    text-shadow: 0 2px 40px rgba(0,0,0,0.4);
  }

  h1 em {
    font-style: normal;
    color: var(--gold);
  }

  .hero-inner > p {
    max-width: 560px;
    color: rgba(247,240,232,0.8);
    font-size: 16px;
    line-height: 1.7;
    text-shadow: 0 1px 16px rgba(0,0,0,0.5);
  }

  /* ── GRID: cards + formulário ── */
  .contato-grid {
    padding: 56px 56px 100px;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 48px;
    align-items: start;
  }

  .left {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card {
    border: 1px solid var(--border);
    background: rgba(247, 240, 232, 0.02);
    border-radius: 18px;
    padding: 22px;
  }

  .card-kicker {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: var(--gold);
    font-weight: 700;
    margin-bottom: 12px;
  }

  .card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .card li {
    position: relative;
    color: var(--dim);
    font-size: 14px;
    line-height: 1.5;
    padding-left: 14px;
  }

  .card li::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: var(--gold);
    position: absolute;
    top: 7px;
    left: 0;
    transform: rotate(45deg);
  }

  .card h2 {
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: clamp(22px, 3.2vw, 32px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 9px;
  }

  .small {
    color: var(--muted);
    font-size: 13px;
    line-height: 1.6;
  }

  .mini-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .mini-grid > div {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--dark-3);
    padding: 12px;
  }

  .mini-grid b {
    display: block;
    color: var(--gold);
    font-family: "Satoshi", "Inter", sans-serif;
    font-size: 24px;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 4px;
  }

  .mini-grid span {
    color: var(--muted);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .form-card {
    border: 1px solid var(--border);
    border-radius: 22px;
    background: var(--dark-3);
    padding: 28px;
  }

  .form-kicker {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: var(--gold);
    font-weight: 700;
    margin-bottom: 16px;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form label span {
    color: var(--text-muted);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .form input,
  .form select,
  .form textarea {
    width: 100%;
    border: 1px solid rgba(247, 240, 232, 0.18);
    border-radius: 10px;
    background: rgba(247, 240, 232, 0.02);
    color: #fff;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    padding: 12px;
  }

  .form select option {
    background-color: #1f1713;
    color: #f7f0e8;
  }

  .form select option:checked,
  .form select option:hover {
    background-color: #2e1e16;
    color: #f7f0e8;
  }

  .form textarea {
    resize: vertical;
    min-height: 90px;
  }

  .row {
    display: grid;
    gap: 10px;
    grid-template-columns: 1fr 1fr;
  }

  .form button {
    margin-top: 6px;
    border: 1px solid rgba(247, 240, 232, 0.26);
    border-radius: 10px;
    background: linear-gradient(135deg, var(--brown), var(--gold));
    color: #fff;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-weight: 800;
    padding: 14px;
    cursor: pointer;
  }

  .form button:hover { opacity: 0.92; }

  /* ── SUCCESS ── */
  .success-wrap {
    min-height: calc(100vh - 64px);
    display: grid;
    place-items: center;
    padding: 30px;
  }

  .success-card {
    width: min(92vw, 520px);
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--dark-3);
    padding: 30px;
    text-align: center;
  }

  .success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    border-radius: 999px;
    border: 1px solid rgba(247, 240, 232, 0.26);
    color: var(--gold);
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }

  .success-card h1 {
    font-size: clamp(30px, 4.4vw, 46px);
    margin-bottom: 8px;
  }

  .success-card p {
    color: var(--dim);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .success-card a {
    display: inline-flex;
    text-decoration: none;
    color: #fff;
    padding: 12px 16px;
    border-radius: 10px;
    border: 1px solid rgba(247, 240, 232, 0.26);
    background: linear-gradient(135deg, var(--brown), var(--gold));
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 800;
  }

  /* marquee colado na base da hero via sobreposição */
  .marquee-bridge {
    position: relative;
    z-index: 10;
    margin-top: -56px;
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .hero {
      height: 100svh;
      min-height: 620px;
      max-height: none;
      justify-content: flex-end;
    }

    .hero-gradient {
      background:
        linear-gradient(to bottom, rgba(7,7,7,0.2) 0%, rgba(7,7,7,0.55) 45%, rgba(7,7,7,0.9) 75%, var(--dark) 100%);
    }

    .hero-inner {
      padding: 0 20px 36px;
    }

    h1 {
      font-size: clamp(30px, 8.5vw, 44px) !important;
      letter-spacing: -0.04em !important;
      line-height: 1.0 !important;
    }

    .hero-inner > p {
      font-size: 14px;
      line-height: 1.6;
    }

    .contato-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 40px 16px 80px;
    }

    .row,
    .mini-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
