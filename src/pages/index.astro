<script>
  // Hero: quando o vídeo acaba, faz crossfade suave pra imagem final
  const heroSection = document.querySelector('.hero-cinematic') as HTMLElement | null;
  const heroVideo = document.getElementById('hero-video') as HTMLVideoElement | null;

  if (heroSection && heroVideo) {
    const showPoster = () => heroSection.classList.add('finished');

    heroVideo.addEventListener('ended', showPoster);

    // fallback: se o vídeo falhar ou não puder tocar, mostra poster
    heroVideo.addEventListener('error', showPoster);
    heroVideo.addEventListener('stalled', () => {
      // se travar por mais de 4s, mostra a imagem
      setTimeout(() => {
        if (heroVideo.readyState < 2) showPoster();
      }, 4000);
    });

    // tenta dar play (alguns navegadores exigem interação)
    const tryPlay = () => {
      heroVideo.play().catch(() => {
        // autoplay bloqueado — já vai pra imagem final
        showPoster();
      });
    };
    tryPlay();
  }
</script>
