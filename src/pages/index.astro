    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--cream);
    margin-bottom: 8px;
  }

  .faq-item p {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .hero-cinematic {
      height: auto;
      min-height: 680px;
    }
    .hero-content {
      padding: 140px 24px 80px;
    }
    .hero-title {
      font-size: clamp(26px, 7vw, 40px);
      letter-spacing: -0.04em;
