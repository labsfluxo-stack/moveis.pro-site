---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import NumbersBar from "../components/NumbersBar.astro";
import CTABox from "../components/CTABox.astro";

const b = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const sobreImages = ['1.webp','2.webp','3.webp','4.webp','5.webp','6.webp','7.webp','8.webp'];

const pilares = [
  {
    icon: "01",
    title: "Especialização",
    desc: "Só loja de móveis médio-alto ticket. Fabricante e revendedor. A gente vive nesse mercado — sabe o que converte e o que é papo.",
  },
  {
    icon: "02",
    title: "Sistema",
    desc: "Tráfego + IA + CRM em pacote fechado. Sem contratar 4 fornecedores que não conversam entre si.",
  },
  {
    icon: "03",
    title: "Resultado",
    desc: "Venda e faturamento — métrica de negócio. Não seguidor, não clique, não métrica de vaidade.",
  },
  {
    icon: "04",
    title: "Velocidade",
    desc: "Setup em 14 dias. Showroom começa a encher em 45. Sem enrolação nem reunião eterna.",
  },
];

const numbers = [
  { value: "14 dias", label: "Pro sistema completo estar rodando" },
  { value: "45 dias", label: "Pro showroom encher de cliente qualificado" },
  { value: "30 leads", label: "Mínimo garantido no primeiro ciclo" },
  { value: "CPL ≤ R$100", label: "Custo máximo por lead qualificado" },
];
---

<BaseLayout
  title="Sobre — Moveis.pro"
  description="A única empresa de marketing no Brasil que trabalha só com loja de móveis médio-alto ticket. Tráfego + IA + CRM num sistema único."
>
  <Nav />
  <main style="padding-top: 0;">

    <!-- ① HERO 2 colunas -->
    <section class="sobre-hero">

      <!-- esquerda: texto -->
      <div class="sobre-hero-text">
        <div class="inline-flex items-center gap-2.5 mb-8" style="color: var(--gold);">
          <span class="block w-7 h-px" style="background: var(--gold);"></span>
          <span class="text-xs font-medium tracking-widest uppercase" style="letter-spacing: 2px;">
            Quem somos
          </span>
        </div>

        <h1
          class="font-display font-black text-white mb-7"
          style="font-size: clamp(40px, 5.4vw, 74px); letter-spacing: -2.4px; line-height: 0.96;"
        >
          A única empresa que trabalha<br />
          <em class="not-italic" style="color: var(--gold);">só com loja de móveis.</em>
        </h1>

        <p class="font-light" style="font-size: 17px; color: var(--dim); line-height: 1.75; max-width: 560px;">
          A Moveis.pro nasceu com uma obsessão: entregar tráfego, IA e atendimento que funcionam
          <b style="color: var(--cream); font-weight: 600;">pra loja de móveis</b>. Enquanto agência
          genérica trata lojista de médio-alto ticket como se fosse Magazine Luiza, a gente fala a
          linguagem do seu showroom. Resultado: campanha mais barata, cliente certo, vendedor que
          fecha.
        </p>
      </div>

      <!-- direita: slideshow automático -->
      <div class="sobre-slides-wrap">
        <!-- glow ambiente atrás das imagens -->
        <div class="sobre-slides-glow"></div>

        {sobreImages.map((img, i) => (
          <img
            class={`sobre-slide${i === 0 ? ' active' : ''}`}
            src={`${b}images/sobre/${img}`}
            alt=""
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        ))}
      </div>

    </section>

    <!-- ② NUMBERS BAR -->
    <div style="padding: 0 56px 76px;">
      <NumbersBar items={numbers} />
    </div>

    <!-- ③ DIFERENCIAIS -->
    <section style="padding: 0 56px 90px;">
      <div class="diferenciais-grid grid gap-4" style="grid-template-columns: repeat(2, 1fr);">
        {
          pilares.map((item) => (
            <article class="rounded-[18px] p-9" style="background: var(--dark-3); border: 1px solid var(--border);">
              <div
                class="inline-flex items-center justify-center mb-5 rounded-full"
                style="width: 34px; height: 34px; border: 1px solid rgba(247,240,232,0.26); color: var(--gold); font-size: 11px; font-weight: 700; letter-spacing: 0.08em;"
              >
                {item.icon}
              </div>
              <h2 class="font-display font-black text-white mb-3" style="font-size: 24px; letter-spacing: -0.8px;">
                {item.title}
              </h2>
              <p class="text-sm font-light leading-relaxed" style="color: var(--muted);">
                {item.desc}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- ④ GARANTIA -->
    <section style="padding: 0 56px 102px;">
      <div
        class="rounded-2xl p-8 md:p-10"
        style="border: 1px solid var(--border); background: linear-gradient(135deg, rgba(184,92,58,0.16), rgba(247,240,232,0.02));"
      >
        <p
          class="text-xs uppercase tracking-widest mb-4"
          style="color: var(--gold); letter-spacing: 0.15em; font-weight: 700;"
        >
          Garantia comercial
        </p>
        <h3 class="font-display font-black text-white mb-4" style="font-size: clamp(26px, 3.2vw, 40px); letter-spacing: -0.04em; line-height: 1.05;">
          Em 45 dias, mínimo de 30 leads qualificados com CPL ≤ R$100.
        </h3>
        <p class="text-sm font-light leading-relaxed" style="color: var(--dim); max-width: 800px;">
          Se a gente não entregar, o segundo mês é por nossa conta. É assim porque a gente acredita no
          sistema — e se não vender, a gente não dorme.
        </p>
      </div>
    </section>

    <!-- ⑤ CTA -->
    <div style="padding: 0 56px 100px;">
      <CTABox
        title={"Topa uma conversa\nde 20 minutos?"}
        subtitle="Diagnóstico gratuito. A gente mapeia o gargalo da sua loja — captação, atendimento ou follow-up — e te entrega um plano prático, pago ou não."
        buttonLabel="Diagnóstico gratuito →"
        buttonHref={`${b}contato`}
      />
    </div>

  </main>
  <Footer />
</BaseLayout>

<script>
  // Clear any previous slideshow interval on re-navigation
  if (window.__sobreSlideInterval) {
    clearInterval(window.__sobreSlideInterval);
    window.__sobreSlideInterval = null;
  }

  document.addEventListener('astro:page-load', () => {
    // Clean up previous interval if page re-loaded
    if (window.__sobreSlideInterval) {
      clearInterval(window.__sobreSlideInterval);
    }

    const slides = Array.from(document.querySelectorAll('.sobre-slide'));
    if (slides.length <= 1) return;

    let current = 0;
    // Ensure first slide is active on load
    slides.forEach((s, i) => {
      s.classList.toggle('active', i === 0);
    });

    window.__sobreSlideInterval = setInterval(() => {
      slides[current].classList.remove('active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('active');
    }, 3200);
  });

  // Also clean up when navigating away
  document.addEventListener('astro:before-swap', () => {
    if (window.__sobreSlideInterval) {
      clearInterval(window.__sobreSlideInterval);
      window.__sobreSlideInterval = null;
    }
  });
</script>

<style>
  /* ── HERO 2 COLUNAS ── */
  .sobre-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    padding: 72px 56px 80px;
    align-items: center;
    min-height: 86vh;
  }

  /* ── SLIDESHOW ── */
  .sobre-slides-wrap {
    position: relative;
    height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* glow ambiente atrás dos móveis */
  .sobre-slides-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 75% 65% at 50% 55%, rgba(184,92,58,0.10) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* no mobile o glow some (gradiente do ::after já cobre) */
  @media (max-width: 768px) {
    .sobre-slides-glow { display: none; }
  }

  /* todas as imagens empilhadas — fade automático */
  .sobre-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
    opacity: 0;
    transition: opacity 1.4s ease;
    z-index: 1;
    /* drop-shadow sutil para dar profundidade nos PNGs sem fundo */
    filter: drop-shadow(0 24px 48px rgba(0,0,0,0.55));
  }

  .sobre-slide.active {
    opacity: 1;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .sobre-hero {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      padding: 72px 40px 64px;
      min-height: auto;
    }
    .sobre-slides-wrap { height: 420px; }
  }

  @media (max-width: 768px) {
    .sobre-hero {
      display: flex;
      flex-direction: column;
      grid-template-columns: unset;
      gap: 0;
      padding: 80px 20px 0;
      min-height: auto;
    }

    .sobre-hero-text h1 {
      font-size: clamp(28px, 8.5vw, 42px) !important;
      letter-spacing: -1.5px !important;
    }

    .sobre-hero-text p {
      font-size: 14px !important;
      max-width: 100% !important;
    }

    /* slideshow aparece abaixo do texto, no fluxo normal */
    .sobre-slides-wrap {
      position: relative;
      height: 300px;
      width: 100%;
      margin-top: 32px;
      flex-shrink: 0;
    }
  }
</style>
